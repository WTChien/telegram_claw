# FastAPI configuration
FLASK_ENV=development
API_HOST=0.0.0.0
API_PORT=8000

# Telegram Bot configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
ADMIN_USER_ID=your_telegram_user_id
NANOCLAW_API_BASE=http://localhost:8000

# Service configuration
KNOWN_SERVICES_JSON=config/services.json
PORT_SCAN_TIMEOUT=0.5
PORT_SCAN_THREADS=10
OLLAMA_CONNECT_TIMEOUT=10
OLLAMA_LIST_TIMEOUT=20
OLLAMA_CHAT_TIMEOUT=300
OLLAMA_GENERATE_TIMEOUT=600
OLLAMA_DEFAULT_MODEL=
OLLAMA_DEFAULT_VISION_MODEL=

# Logging configuration
LOG_LEVEL=INFO
LOG_FILE=logs/nanoclaw.log
